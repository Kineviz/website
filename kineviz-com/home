(function() {
  var freeDomains = ['gmail.com','yahoo.com','hotmail.com',
    'outlook.com','aol.com','icloud.com','protonmail.com',
    'live.com','me.com','msn.com'];
 
  document.addEventListener('submit', function(e) {
    var form = e.target;
    if (!form.matches('.form-wrapper form')) return;
    var emailInput = form.querySelector('input[type="email"]');
    if (!emailInput) return;
    var domain = emailInput.value.split('@')[1];
    if (domain && freeDomains.indexOf(domain.toLowerCase()) > -1) {
      e.preventDefault();
      e.stopPropagation();
      var existing = form.querySelector('.kv-email-warning');
      if (existing) existing.remove();
      var warning = document.createElement('p');
      warning.className = 'kv-email-warning';
      warning.style.cssText = 'color:#c0392b;font-size:13px;margin:8px 0;';
      warning.textContent = 'Please use your work email so we can route ' +
        'you to the right specialist.';
      emailInput.parentNode.appendChild(warning);
      emailInput.focus();
      return false;
    }
  }, true);
})();
